# Copy to .env and fill in. Never commit .env.
# These are only read by `npm run build:routes`.

# Get an API key from https://ridewithgps.com/api
RWGPS_API_KEY=

# Auth token for the user account that owns the routes.
# Obtain via the RWGPS auth flow (POST /users/current.json with email+password
# returns user.auth_token), or generate one in your account settings.
RWGPS_AUTH_TOKEN=

# Optional: fall back to this privacy code for unlisted routes that need one.
RWGPS_COLLECTION_PRIVACY_CODE=
